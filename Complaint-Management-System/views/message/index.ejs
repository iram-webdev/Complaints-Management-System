<%- include("../partials/sidebar") %>

<div class="ml-0 md:ml-64 bg-gray-100 min-h-screen flex flex-col">

    <%- include("../partials/navbar") %>

    <div class="p-6 flex-1 flex flex-col">

        <!-- HEADER -->
        <div class="mb-4">
            <h1 class="text-2xl font-bold">💬 Live Chat</h1>
            <p class="text-gray-500 text-sm">Real-time messaging system</p>
        </div>

        <!-- CHAT BOX -->
        <div id="chatBox"
            class="flex-1 bg-white rounded-2xl shadow-md p-4 overflow-y-auto space-y-3">

            <% messages.forEach(m => { %>

                <div class="flex <%= (m.sender && user && m.sender._id.toString() === user._id?.toString()) ? 'justify-end' : 'justify-start' %>">

                    <div class="<%= (m.sender && user && m.sender._id.toString() === user._id?.toString()) ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-800' %> px-4 py-2 rounded-2xl max-w-xs shadow">

                        <p class="text-xs font-semibold mb-1 opacity-80">
                            <%= m.sender ? m.sender.name : "Unknown User" %>
                        </p>

                        <p class="text-sm">
                            <%= m.message %>
                        </p>

                    </div>

                </div>

            <% }) %>

        </div>

        <!-- INPUT -->
        <form id="chatForm" class="mt-4 flex gap-2">

            <input id="msg"
                class="flex-1 border rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-400"
                placeholder="Type your message..."
                autocomplete="off">

            <button class="bg-blue-600 hover:bg-blue-700 text-white px-6 rounded-xl transition">
                Send
            </button>

        </form>

    </div>
</div>

<!-- SOCKET -->
<script src="/socket.io/socket.io.js"></script>

<script>
    const socket = io();
    const form = document.getElementById("chatForm");
    const input = document.getElementById("msg");
    const chatBox = document.getElementById("chatBox");

    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const message = input.value.trim();
        if (!message) return;

        await fetch("/message/send", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ message })
        });

        input.value = "";
    });

    socket.on("receive_message", (msg) => {

        const isMe = msg.sender && msg.sender._id === "<%= user._id %>";

        const div = document.createElement("div");
        div.className = `flex ${isMe ? 'justify-end' : 'justify-start'}`;

        div.innerHTML = `
            <div class="${isMe ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-800'} px-4 py-2 rounded-2xl max-w-xs shadow">
                <p class="text-xs font-semibold mb-1">${msg.sender?.name || 'Unknown'}</p>
                <p class="text-sm">${msg.message}</p>
            </div>
        `;

        chatBox.appendChild(div);
        chatBox.scrollTop = chatBox.scrollHeight;
    });
</script>