<%- include("../partials/sidebar") %>

<div class="ml-0 md:ml-64 bg-gray-50 min-h-screen">

    <%- include("../partials/navbar") %>

    <div class="p-6 md:p-8">

        <!-- HEADER -->
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Reports Dashboard</h1>
            <p class="text-gray-500">Analytics & Complaint Overview</p>
        </div>

        <!-- STATS CARDS -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

            <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition border-l-4 border-indigo-500">
                <p class="text-gray-500">Total Users</p>
                <h2 class="text-3xl font-bold mt-2"><%= totalUsers %></h2>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition border-l-4 border-teal-500">
                <p class="text-gray-500">Total Complaints</p>
                <h2 class="text-3xl font-bold mt-2"><%= totalComplaints %></h2>
            </div>

            <div class="bg-yellow-50 p-6 rounded-2xl shadow border-l-4 border-yellow-500">
                <p class="text-gray-600">Pending</p>
                <h2 class="text-3xl font-bold text-yellow-600 mt-2"><%= pending %></h2>
            </div>

            <div class="bg-blue-50 p-6 rounded-2xl shadow border-l-4 border-blue-500">
                <p class="text-gray-600">In Progress</p>
                <h2 class="text-3xl font-bold text-blue-600 mt-2"><%= inProgress %></h2>
            </div>

            <div class="bg-green-50 p-6 rounded-2xl shadow border-l-4 border-green-500">
                <p class="text-gray-600">Resolved</p>
                <h2 class="text-3xl font-bold text-green-600 mt-2"><%= resolved %></h2>
            </div>

            <div class="bg-red-50 p-6 rounded-2xl shadow border-l-4 border-red-500">
                <p class="text-gray-600">Rejected</p>
                <h2 class="text-3xl font-bold text-red-600 mt-2"><%= rejected %></h2>
            </div>

        </div>

        <!-- CHARTS -->
        <div class="mt-10 grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- PIE CHART -->
            <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
                <h2 class="text-xl font-bold mb-4">Complaints Distribution</h2>
                <canvas id="statusChart"></canvas>
            </div>

            <!-- BAR CHART -->
            <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
                <h2 class="text-xl font-bold mb-4">System Overview</h2>
                <canvas id="overviewChart"></canvas>
            </div>

        </div>

        <!-- RECENT COMPLAINTS -->
        <div class="mt-10 bg-white rounded-2xl shadow">

            <div class="p-5 border-b flex justify-between items-center">
                <h2 class="text-xl font-bold">Recent Complaints</h2>
                <span class="text-sm text-gray-400">Latest 10 records</span>
            </div>

            <div class="overflow-x-auto">

                <table class="w-full">

                    <thead class="bg-gray-100 text-gray-600 text-sm">
                        <tr>
                            <th class="p-3 text-left">Title</th>
                            <th class="p-3 text-left">User</th>
                            <th class="p-3 text-left">Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% recentComplaints.forEach(c => { %>
                            <tr class="border-t hover:bg-gray-50 transition">

                                <td class="p-3 font-medium"><%= c.title %></td>

                                <td class="p-3 text-gray-600">
                                    <%= c.user ? c.user.name : "Unknown User" %>
                                </td>

                                <td class="p-3">
                                    <span class="px-3 py-1 text-xs rounded-full text-white
                                        <%= c.status === 'Pending' ? 'bg-yellow-500' : '' %>
                                        <%= c.status === 'In Progress' ? 'bg-blue-500' : '' %>
                                        <%= c.status === 'Resolved' ? 'bg-green-500' : '' %>
                                        <%= c.status === 'Rejected' ? 'bg-red-500' : '' %>
                                    ">
                                        <%= c.status %>
                                    </span>
                                </td>

                            </tr>
                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>
</div>

<!-- CHART.JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // PIE CHART
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Pending', 'In Progress', 'Resolved', 'Rejected'],
            datasets: [{
                data: [
                    <%= pending %>,
                    <%= inProgress %>,
                    <%= resolved %>,
                    <%= rejected %>
                ],
                backgroundColor: [
                    '#facc15',
                    '#3b82f6',
                    '#22c55e',
                    '#ef4444'
                ],
                borderWidth: 2
            }]
        }
    });

    // BAR CHART
    new Chart(document.getElementById('overviewChart'), {
        type: 'bar',
        data: {
            labels: ['Users', 'Complaints'],
            datasets: [{
                label: 'Count',
                data: [
                    <%= totalUsers %>,
                    <%= totalComplaints %>
                ],
                backgroundColor: ['#6366f1', '#14b8a6'],
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                }
            }
        }
    });
</script>