<%- include("../partials/sidebar") %>

<div class="ml-64">

<%- include("../partials/navbar") %>

<div class="p-8">

<div class="bg-white p-6 rounded-xl shadow">

<h2 class="text-2xl font-bold mb-5">
Edit User
</h2>

<form action="/users/edit/<%= user._id %>" method="POST">

<input
type="text"
name="name"
value="<%= user.name %>"
class="border w-full p-3 rounded mb-4">

<input
type="email"
name="email"
value="<%= user.email %>"
class="border w-full p-3 rounded mb-4">

<select
name="role"
class="border w-full p-3 rounded mb-4">

<option value="user"
<%= user.role=="user"?"selected":"" %>>

User

</option>

<option value="admin"
<%= user.role=="admin"?"selected":"" %>>

Admin

</option>

</select>

<button
class="bg-blue-600 text-white px-6 py-3 rounded">

Update User

</button>

</form>

</div>

</div>

</div>