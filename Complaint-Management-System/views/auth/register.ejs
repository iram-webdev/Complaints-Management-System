<div class="min-h-screen flex items-center justify-center relative overflow-hidden px-4">

    <!-- 🌈 BACKGROUND -->
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-600 via-blue-600 to-cyan-500"></div>

    <!-- blur shapes -->
    <div class="absolute w-96 h-96 bg-white opacity-10 rounded-full blur-3xl top-[-120px] left-[-120px]"></div>
    <div class="absolute w-96 h-96 bg-pink-300 opacity-10 rounded-full blur-3xl bottom-[-120px] right-[-120px]"></div>

    <!-- CARD -->
    <div class="relative w-full max-w-md">

        <div class="bg-white/90 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/30 overflow-hidden">

            <!-- HEADER -->
            <div class="bg-gradient-to-r from-indigo-600 to-blue-600 p-6 text-center">

                <div class="w-16 h-16 mx-auto bg-white text-indigo-600 rounded-2xl flex items-center justify-center text-xl font-bold shadow-lg">
                    CM
                </div>

                <h1 class="text-2xl font-bold text-white mt-3">
                    Create Account
                </h1>

                <p class="text-blue-100 text-sm mt-1">
                    Join Complaint Management System
                </p>

            </div>

            <!-- FORM -->
            <div class="p-6 space-y-5">

                <form action="/register" method="POST" class="space-y-4">

                    <!-- NAME -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">
                            Full Name
                        </label>

                        <input
                            type="text"
                            name="name"
                            required
                            class="w-full border border-gray-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                            placeholder="Enter your name"
                        >
                    </div>

                    <!-- EMAIL -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">
                            Email Address
                        </label>

                        <input
                            type="email"
                            name="email"
                            required
                            class="w-full border border-gray-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                            placeholder="example@email.com"
                        >
                    </div>

                    <!-- PASSWORD -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">
                            Password
                        </label>

                        <input
                            type="password"
                            name="password"
                            required
                            class="w-full border border-gray-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                            placeholder="Create password"
                        >
                    </div>

                    <!-- BUTTON -->
                    <button
                        type="submit"
                        class="w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-blue-600 hover:to-indigo-700 text-white py-3 rounded-xl font-semibold transition transform hover:scale-[1.02] shadow-lg">

                        Create Account

                    </button>

                </form>

                <!-- DIVIDER -->
                <div class="flex items-center gap-3 my-4">
                    <div class="h-px bg-gray-200 flex-1"></div>
                    <span class="text-xs text-gray-400">OR</span>
                    <div class="h-px bg-gray-200 flex-1"></div>
                </div>

                <!-- LOGIN LINK -->
                <p class="text-center text-sm text-gray-600">
                    Already have an account?
                    <a href="/login" class="text-blue-600 font-semibold hover:underline">
                        Sign in
                    </a>
                </p>

            </div>
        </div>

        <!-- FOOTER -->
        <p class="text-center text-xs text-white/80 mt-4">
            © 2026 Complaint Management System
        </p>

    </div>

</div>